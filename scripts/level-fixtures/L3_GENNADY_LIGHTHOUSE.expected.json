    {
      "name": "Ловушка 6 — Relay + Routing (нет TLS и DISCOVERY — ловушка)",
      "placements": {
        "l3_r_dns":    "S_DNS",
        "l3_r_route1": "S_TRAFFIC_SPLIT"
      },
      "installedMatrixIds": ["net_l3_relay", "net_l3_routing"],
