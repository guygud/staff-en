      },
      "installedMatrixIds": ["net_l3_infra", "net_l3_routing"],
      "expected": {
        "outcome": "fail",
        "fatalStatusesContains": ["F5_FRAGILITY"]
      }
    },
    {
      "name": "Ловушка 4 — без карты маршрутизации (D_ROUTING_AMBIGUITY → F7, буф не выдан)",
      "placements": {
        "l3_dns":   "S_DNS",
        "l3_tls":   "S_TLS_CERT",
        "l3_disc1": "S_HEALTHCHECK"
      },
      "installedMatrixIds": ["net_l3_infra", "net_l3_routing"],
