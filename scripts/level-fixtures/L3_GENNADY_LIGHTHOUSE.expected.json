    {
      "name": "Ловушка 5 — без матрицы маршрутов (нет NET_ROUTING слота)",
      "placements": {
        "l3_dns":   "S_DNS",
        "l3_tls":   "S_TLS_CERT",
        "l3_disc1": "S_HEALTHCHECK"
      },
      "installedMatrixIds": ["net_l3_infra"],
      "expected": {
        "outcome": "fail",
        "fatalStatusesContains": ["F7_CONFUSION"]
