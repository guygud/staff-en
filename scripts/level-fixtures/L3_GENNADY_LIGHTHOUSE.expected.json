        "auraTotalRange":  [3, 3]
      }
    },
    {
      "name": "Ловушка 1 — Путь B без ритуала (бюджет превышен)",
      "placements": {
        "l3_dns":    "S_PRIVATE_DNS",
        "l3_route1": "S_LOCALITY_ROUTING"
      },
      "installedMatrixIds": ["net_l3_infra", "net_l3_routing"],
      "expected": {
        "outcome": "fail"
      }
    },
    {
      "name": "Ловушка 2 — DNS без TLS (каскад D_DNS_EXPOSED → F3_COMPROMISE)",
