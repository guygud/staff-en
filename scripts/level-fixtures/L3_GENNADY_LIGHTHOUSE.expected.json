      },
      "installedMatrixIds": ["net_l3_infra", "net_l3_routing"],
      "expected": {
        "outcome": "fail",
        "fatalStatusesContains": ["F3_COMPROMISE"]
      }
    },
    {
      "name": "Ловушка 3 — TrafficSplit без HealthCheck (D_SPLIT_OVERLOAD → F5_FRAGILITY)",
      "placements": {
        "l3_dns":    "S_DNS",
        "l3_tls":    "S_TLS_CERT",
