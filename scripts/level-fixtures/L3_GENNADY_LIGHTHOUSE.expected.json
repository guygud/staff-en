{
  "levelId": "L3_GENNADY_LIGHTHOUSE",
  "scenarios": [
    {
      "name": "Путь A — дешёвые карты, двойной каскад (Ending A)",
      "placements": {
        "l3_dns":    "S_DNS",
        "l3_tls":    "S_TLS_CERT",
        "l3_route1": "S_TRAFFIC_SPLIT",
        "l3_disc1":  "S_HEALTHCHECK"
      },
      "installedMatrixIds": ["net_l3_infra", "net_l3_routing"],
      "expected": {
        "outcome": "pass",
        "missingRequirements": [],
        "fatalStatuses": [],
        "coinsSpentRange": [11, 11],
        "auraTotalRange":  [4, 4]
      }
    },
    {
      "name": "Путь B — дорогие карты, ритуал (Ending B)",
      "placements": {
        "l3_base_rit": "R_PATRON_SEAL",
        "l3_dns":      "S_PRIVATE_DNS",
        "l3_route1":   "S_LOCALITY_ROUTING"
      },
      "installedMatrixIds": ["net_l3_infra", "net_l3_routing"],
      "expected": {
        "outcome": "pass",
        "missingRequirements": [],
        "fatalStatuses": [],
        "coinsSpentRange": [17, 17],
        "auraTotalRange":  [3, 3]
      }
    },
    {
      "name": "Путь B (alt) — Почтовая станция + ритуал (минималистичный)",
