        "l3_r_rit":    "R_PATRON_SEAL",
        "l3_r_dns":    "S_PRIVATE_DNS",
        "l3_r_route1": "S_LOCALITY_ROUTING"
      },
      "installedMatrixIds": ["net_l3_relay"],
      "expected": {
        "outcome": "pass",
