{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name":        { "type": "string" },
    "description": { "type": "string" },
    "currencies": {
      "type": "object",
      "properties": {
        "gold": { "type": "integer" },
        "aura": { "type": "integer" }
      },
      "required": ["gold", "aura"],
      "additionalProperties": false
    },
    "states": {
      "type": "array",
      "description": "Баффы которые карта даёт + дебаффы которые добавляет (каскад)",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "icon": { "type": "string", "description": "Example: images/icons/чистота" },
          "type": { "type": "string", "enum": ["buff", "debuff"] }
        },
        "required": ["name", "icon", "type"],
        "additionalProperties": false
      }
    },
    "resolves": {
      "type": "array",
      "description": "Статусы которые карта снимает",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "icon": { "type": "string", "description": "Example: images/icons/f3_compromise" }
        },
        "required": ["name", "icon"],
        "additionalProperties": false
      }
    },
    "types": {
      "type": "array",
      "description": "Типы слотов в которые карту можно положить. Cocos сравнивает с slot в матрице.",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["logs", "filters", "retention", "quota",
                 "dns", "tls", "auth", "routing", "discovery",
                 "cicd", "canary", "ritual"]
      }
    }
  },
  "required": ["name", "description", "currencies", "states", "resolves", "types"],
  "additionalProperties": false
}
