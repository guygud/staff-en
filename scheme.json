{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "integer",
      "description": "Номер уровня"
    },
    "customer": {
      "type": "object",
      "description": "Заказчик — кто даёт задание",
      "properties": {
        "name":        { "type": "string", "description": "Имя заказчика" },
        "avatar":      { "type": "string", "description": "Ссылка на аватар. Example: images/avatars/level-1.png" },
        "description": { "type": "string", "description": "Описание задания" },
        "budget":      { "$ref": "#/$defs/currencies", "description": "Бюджет заказчика" },
        "debuff": {
          "type": "string",
          "enum": ["slow", "blind", "stun", ""],
          "description": "Визуальный дебафф уровня. Пустая строка = нет дебаффа"
        }
      },
      "required": ["name", "avatar", "description", "budget"],
      "additionalProperties": false
    },
    "cards": {
      "type": "array",
      "description": "ID карт доступных на уровне (ключи из cards.json). Cocos фильтрует по совпадению card.types со слотом матрицы.",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "matrices": {
      "type": "array",
      "description": "Матрицы уровня",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name":        { "type": "string", "description": "Отображаемое название матрицы" },
          "description": { "type": "string", "description": "Краткое описание назначения матрицы" },
          "isRequired": {
            "type": "boolean",
            "description": "true — предустановлена, не стоит монет; false — игрок выбирает и покупает"
          },
          "currencies": {
            "$ref": "#/$defs/goldOnly",
            "description": "Стоимость установки. Только для isRequired = false"
          },
          "slots": {
            "type": "array",
            "description": "Конкретные типы слотов. Cocos подставляет карты у которых card.types содержит этот тип.",
            "minItems": 1,
            "maxItems": 5,
            "items": {
              "type": "string",
              "enum": ["logs", "filters", "retention", "quota",
                       "dns", "tls", "auth", "routing", "discovery",
                       "cicd", "canary", "ritual"]
            }
          }
        },
        "required": ["isRequired", "slots"],
        "additionalProperties": false
      }
    }
  },
  "required": ["id", "customer", "cards", "matrices"],
  "additionalProperties": false,

  "$defs": {
    "currencies": {
      "type": "object",
      "properties": {
        "gold": { "type": "integer" },
        "aura": { "type": "integer" }
      },
      "required": ["gold", "aura"],
      "additionalProperties": false
    },
    "goldOnly": {
      "type": "object",
      "properties": {
        "gold": { "type": "integer" }
      },
      "required": ["gold"],
      "additionalProperties": false
    }
  }
}
